# Theme-specific config. Layered on top of themes/default/config.yml at runtime,
# so you only need to declare keys you want to override or add.
#
# Examples:
#   Branding:
#     Logo: "/themes/{{.Name}}/static/logo.svg"
#     Discord: "https://discord.gg/your-server"
#
#   Navbar:
#     Items:
#       - Label: "Custom"
#         Href: "/custom"
#         Icon: "star"
