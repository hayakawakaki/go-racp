package transport

import (
	"time"
)

templ categoryChip(display string) {
	<span class="inline-block text-xs font-medium px-2 py-0.5 rounded bg-blue-100 text-blue-800">{ display }</span>
}

templ postedAt(t time.Time) {
	<time datetime={ t.UTC().Format(time.RFC3339) } class="text-xs text-gray-500">
		{ t.UTC().Format("Jan 2, 2006") }
	</time>
}
