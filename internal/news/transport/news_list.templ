package transport

import (
	"fmt"

	"github.com/hayakawakaki/go-racp/internal/httpx"
	newsapp "github.com/hayakawakaki/go-racp/internal/news/app"
	"github.com/hayakawakaki/go-racp/internal/news/domain"
)

type NewsListState struct {
	Items            []newsapp.NewsItem
	Categories       []domain.Category
	SelectedCategory string
	CanManage        bool
}

templ newsListPage(layout httpx.Layout, state NewsListState) {
	@httpx.Base(layout, "News") {
		<div class="w-full max-w-3xl self-start p-6">
			<div class="flex items-center justify-between mb-6 gap-3">
				<h1 class="text-2xl font-semibold text-gray-900">News</h1>
				<div class="flex items-center gap-3">
					<form method="get" action="/news" class="flex items-center gap-2">
						<label for="category" class="text-sm text-gray-600">Category</label>
						<select id="category" name="category" onchange="this.form.submit()" class="text-sm border border-gray-300 rounded px-2 py-1">
							<option value="" selected?={ state.SelectedCategory == "" }>All</option>
							for _, c := range state.Categories {
								<option value={ c.Key } selected?={ c.Key == state.SelectedCategory }>{ c.Display }</option>
							}
						</select>
					</form>
					if state.CanManage {
						<a href="/news/create" class="rounded bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-3 py-1.5 transition">New post</a>
					}
				</div>
			</div>
			if len(state.Items) == 0 {
				<div class="bg-white border border-gray-200 rounded-lg shadow-sm p-10 text-center">
					<p class="text-gray-700 font-medium">No news yet</p>
				</div>
			} else {
				<ul class="space-y-3">
					for _, item := range state.Items {
						<li class="bg-white border border-gray-200 rounded-lg shadow-sm p-4">
							<a href={ templ.URL(fmt.Sprintf("/news/%d", item.ID)) } class="block">
								<div class="flex items-center justify-between gap-3">
									<h2 class="text-lg font-medium text-gray-900 truncate">{ item.Title }</h2>
									@categoryChip(item.CategoryDisplay)
								</div>
								<div class="mt-1">
									@postedAt(item.CreatedAt)
								</div>
							</a>
						</li>
					}
				</ul>
			}
		</div>
	}
}
