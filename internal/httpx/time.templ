package httpx

templ LocalTime(iso string) {
	if iso == "" {
		<time>never</time>
	} else {
		<time
			datetime={ iso }
			x-data
			x-init="(()=>{const d=new Date($el.getAttribute('datetime'));if(isNaN(d))return;const p=n=>String(n).padStart(2,'0');$el.textContent=`${d.getFullYear()}-${p(d.getMonth()+1)}-${p(d.getDate())} - ${p(d.getHours())}:${p(d.getMinutes())}`;})()"
		>{ iso }</time>
	}
}
