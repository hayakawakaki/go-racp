		ColorStone:   "bg-transparent text-stone-700 hover:text-stone-900 active:text-stone-950 focus-visible:ring-stone-500 px-0 py-0",
	},
}

func buttonVariantClasses(variant ButtonVariant, color Color) string {
	return buttonClassMap[variant][color]
}

func buttonType(p ButtonProps) string {
	if p.Type == "" {
		return string(ButtonTypeButton)
	}

	return string(p.Type)
}

func buttonAttrs(p ButtonProps) templ.Attributes {
	attrs := templ.Attributes{}

	if p.AriaLabel != "" {
		attrs["aria-label"] = p.AriaLabel
	}

	if p.Loading {
		attrs["aria-busy"] = "true"
	}

	if p.ID != "" {
		attrs["id"] = p.ID
	}

	if p.Name != "" {
		attrs["name"] = p.Name
	}

	if p.Href != "" && p.Target != "" {
		attrs["target"] = p.Target

		if p.Target == "_blank" {
			attrs["rel"] = "noopener noreferrer"
		}
	}

	if p.Href == "" && p.Form != "" {
		attrs["form"] = p.Form
	}

	return MergeAttr(attrs, p.Attrs)
}

templ buttonSpinner() {
	<svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
		<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
		<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 0 1 8-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 0 1 4 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
	</svg>
}

templ buttonInner(p ButtonProps) {
	if p.Loading {
		@buttonSpinner()
	} else if p.LeftIcon != nil {
		@p.LeftIcon
	}
	{ children... }
	if !p.Loading && p.RightIcon != nil {
		@p.RightIcon
	}
}

templ Button(p ButtonProps) {
	if p.Href != "" {
		if p.Disabled || p.Loading {
			<a role="button" aria-disabled="true" tabindex="-1" class={ buttonClasses(p) } { buttonAttrs(p)... }>
				@buttonInner(p) {
					{ children... }
				}
			</a>
		} else {
			<a href={ p.Href } class={ buttonClasses(p) } { buttonAttrs(p)... }>
				@buttonInner(p) {
					{ children... }
				}
			</a>
		}
	} else {
		<button type={ buttonType(p) } disabled?={ p.Disabled || p.Loading } class={ buttonClasses(p) } { buttonAttrs(p)... }>
			@buttonInner(p) {
				{ children... }
			}
		</button>
	}
}

