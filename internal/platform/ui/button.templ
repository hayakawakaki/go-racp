package ui

type ButtonVariant string

const (
	ButtonSolid   ButtonVariant = "solid"
	ButtonOutline ButtonVariant = "outline"
	ButtonGhost   ButtonVariant = "ghost"
	ButtonSubtle  ButtonVariant = "subtle"
	ButtonLink    ButtonVariant = "link"
)

type ButtonType string

const (
	ButtonTypeButton ButtonType = "button"
	ButtonTypeSubmit ButtonType = "submit"
)

type ButtonProps struct {
	LeftIcon  templ.Component
	RightIcon templ.Component
	Attrs     templ.Attributes
	Variant   ButtonVariant
	Color     Color
	Size      Size
	Rounded   Size
	Type      ButtonType
	Href      string
	Target    string
	Form      string
	Class     string
	AriaLabel string
	ID        string
	Name      string
	Disabled  bool
	Loading   bool
}

func buttonClasses(p ButtonProps) string {
	variant := p.Variant
	if variant == "" {
		variant = ButtonSolid
	}

	size := p.Size
	if size == "" {
		size = MD
	}

	base := "inline-flex items-center justify-center gap-2 font-medium cursor-pointer transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed aria-disabled:opacity-50 aria-disabled:cursor-not-allowed aria-disabled:pointer-events-none"

	var sizeClasses string

	switch size {
	case SM:
		sizeClasses = "px-3 py-1.5 text-sm"
	case LG:
		sizeClasses = "px-6 py-3 text-base"
	default:
		sizeClasses = "px-4 py-2 text-sm"
	}

	color := p.Color
	if color == "" {
		color = ColorNeutral
	}

	return Merge(base, sizeClasses, roundedClass(p.Rounded), buttonVariantClasses(variant, color), p.Class)
}

