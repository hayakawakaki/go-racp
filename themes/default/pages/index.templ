package pages

import (
	"github.com/hayakawakaki/go-racp/internal/platform/httpx"
	"github.com/hayakawakaki/go-racp/internal/platform/themepage"
)

templ Index(page themepage.Ctx) {
	@httpx.ActiveBase(page.Layout, "Home") {
		<div class="w-full max-w-md bg-white rounded-lg shadow-md p-8 text-center space-y-4">
			<h1 class="text-2xl font-semibold text-gray-900">{ page.Layout.ServerName }</h1>
			<p class="text-gray-700">Welcome to the control panel.</p>
		</div>
	}
}
